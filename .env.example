OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ─────────────────────────────────────────────────────────────
# IDENTITY 1 — Telegram BOT (from @BotFather)
# Used for: sending review messages, the Publish/Rewrite/Skip
# buttons, and PUBLISHING approved posts to the channel.
# This is the ONLY identity that ever publishes anything.
# ─────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=@tonkoff_crypto
# Your MAIN personal Telegram ID — receives review messages + cost alerts.
OWNER_TELEGRAM_ID=312695586
REVIEW_CHAT_ID=312695586

# ─────────────────────────────────────────────────────────────
# IDENTITY 2 — Telegram READER account (Telethon user session)
# A SEPARATE Telegram account created only for this bot.
# Used ONLY for: reading source Telegram channels via Telethon.
# It must NEVER publish. Do NOT use your main personal account.
# Generate TELEGRAM_STRING_SESSION from this reader account with
# generate_session.py. Never commit it — paste it into Railway only.
# ─────────────────────────────────────────────────────────────
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_STRING_SESSION=

AUTO_PUBLISH=false
POSTING_REQUIRES_APPROVAL=true

MAX_POSTS_PER_DAY=6
MIN_POSTS_PER_DAY=5
MAX_AI_CALLS_PER_DAY=12
MAX_REWRITE_PER_POST=3
MAX_TOKENS_PER_POST=1500
MAX_SOURCE_POSTS_PER_CHANNEL=20
LOOKBACK_HOURS=24

ENABLE_SECONDARY_SOURCES=false
MAX_SECONDARY_SOURCES=3
ENABLE_MEDIA_DOWNLOAD=false
ENABLE_COST_GUARD=true

TELEGRAM_CUSTOM_EMOJI_ENABLED=true
TELEGRAM_CUSTOM_EMOJI_FALLBACK=true
