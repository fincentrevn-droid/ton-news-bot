OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ─────────────────────────────────────────────────────────────
# IDENTITY 1 — Telegram BOT (from @BotFather)
# Used for: sending review messages, the Publish/Rewrite/Skip
# buttons, and PUBLISHING approved posts to the channel.
# This is the ONLY identity that ever publishes anything.
# ─────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=@tonkoff_crypto
# Your MAIN personal Telegram ID — receives review messages + cost alerts.
OWNER_TELEGRAM_ID=312695586
REVIEW_CHAT_ID=312695586

# ─────────────────────────────────────────────────────────────
# IDENTITY 2 — Telegram READER account (Telethon user session)
# A SEPARATE Telegram account created only for this bot.
# Used ONLY for: reading source Telegram channels via Telethon.
# It must NEVER publish. Do NOT use your main personal account.
# Generate TELEGRAM_STRING_SESSION from this reader account with
# generate_session.py. Never commit it — paste it into Railway only.
# ─────────────────────────────────────────────────────────────
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_STRING_SESSION=

# ─────────────────────────────────────────────────────────────
# Publishing behavior
# ─────────────────────────────────────────────────────────────
AUTO_PUBLISH=true
POSTING_REQUIRES_APPROVAL=false

# ─────────────────────────────────────────────────────────────
# Daily posting targets
# ─────────────────────────────────────────────────────────────
MIN_AUTO_POSTS_PER_DAY=6
MAX_AUTO_POSTS_PER_DAY=8
TARGET_AUTO_POSTS_PER_DAY=7

# ─────────────────────────────────────────────────────────────
# Posting window (Kyiv timezone)
# Posts are only published during this window.
# ─────────────────────────────────────────────────────────────
POSTING_TIMEZONE=Europe/Kyiv
POSTING_START_TIME=09:00
POSTING_END_TIME=23:30

# ─────────────────────────────────────────────────────────────
# Night pause — no publishing during deep night
# ─────────────────────────────────────────────────────────────
NIGHT_PAUSE_ENABLED=true
NIGHT_PAUSE_START=00:00
NIGHT_PAUSE_END=08:30

# ─────────────────────────────────────────────────────────────
# Spacing between posts (natural distribution across the day)
# ─────────────────────────────────────────────────────────────
MIN_MINUTES_BETWEEN_POSTS=75
MAX_MINUTES_BETWEEN_POSTS=180
POSTING_RANDOM_DELAY_ENABLED=true
POSTING_RANDOM_DELAY_MINUTES=25

# Minimum confidence for auto-publish (high or medium)
AUTO_PUBLISH_MIN_CONFIDENCE=medium

# ─────────────────────────────────────────────────────────────
# AI usage limits (cost guard)
# ─────────────────────────────────────────────────────────────
MAX_POSTS_PER_DAY=8
MIN_POSTS_PER_DAY=6
MAX_AI_CALLS_PER_DAY=12
MAX_REWRITE_PER_POST=3
MAX_TOKENS_PER_POST=1500
MAX_SOURCE_POSTS_PER_CHANNEL=20
LOOKBACK_HOURS=24

ENABLE_SECONDARY_SOURCES=false
MAX_SECONDARY_SOURCES=3
ENABLE_MEDIA_DOWNLOAD=false
ENABLE_COST_GUARD=true

# ─────────────────────────────────────────────────────────────
# AI quality control — check every post before auto-publishing
# score >= 80: auto-publish | 60-79: rewrite once | <60: manual review
# ─────────────────────────────────────────────────────────────
ENABLE_AI_QUALITY_CHECK=true
QUALITY_CHECK_MIN_SCORE=80
MAX_AUTO_QUALITY_REWRITES=1

TELEGRAM_CUSTOM_EMOJI_ENABLED=true
TELEGRAM_CUSTOM_EMOJI_FALLBACK=true
